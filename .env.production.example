# ════════════════════════════════════════════════════════════════════════════
# Kankaverse — PRODUCTION env (VPS).  KOPYALA: cp .env.production.example .env.production
# Bu dosya .env.production olarak doldurulur ve ASLA commit edilmez (.gitignore'da).
# Çalıştır: docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
# ════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# ── Domain / origin ──────────────────────────────────────────────────────────
# FRONTEND_URL: CORS + WS origin + e-posta linkleri. SLASH'SIZ. Kendi domain'in.
FRONTEND_URL=https://kankaverse.com
# Web build-time API URL (Vite gömer). docker-compose.prod.yml build arg'ına geçer.
VITE_API_URL=https://api.kankaverse.com
# web ve api aynı kök domain (kankaverse.com) → same-site → lax yeterli (none gerekmez).
COOKIE_SAMESITE=lax

# ── PostgreSQL (compose iç servisi: host = 'postgres') ───────────────────────
POSTGRES_USER=kankaverse
POSTGRES_PASSWORD=DEGISTIR_guclu_rastgele_parola
POSTGRES_DB=kankaverse
DATABASE_URL=postgresql://kankaverse:DEGISTIR_guclu_rastgele_parola@postgres:5432/kankaverse?schema=public

# ── Redis (compose iç servisi: host = 'redis') ───────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth secret'leri  (üret: openssl rand -base64 48) ────────────────────────
JWT_ACCESS_SECRET=DEGISTIR_uzun_rastgele
JWT_REFRESH_SECRET=DEGISTIR_uzun_rastgele_farkli
# TOTP_ENC_KEY: TAM 32 byte base64.  Üret: openssl rand -base64 32
TOTP_ENC_KEY=DEGISTIR_32_byte_base64

# ── E-posta (Resend — prod'da ZORUNLU) ───────────────────────────────────────
RESEND_API_KEY=re_DEGISTIR
EMAIL_FROM=noreply@kankaverse.com

# ── LiveKit (ses/video — prod'da ZORUNLU, fail-fast) ─────────────────────────
LIVEKIT_API_KEY=DEGISTIR
LIVEKIT_API_SECRET=DEGISTIR
LIVEKIT_URL=wss://DEGISTIR.livekit.cloud

# ── Kayıt modu (kapalı-test) ─────────────────────────────────────────────────
# İLK DEPLOY: 'open' bırak → sahip hesabını aç + isModerator=true yap + davet kodu üret.
# SONRA: 'invite' yap + api'yi yeniden başlat (açık-kayıt kapanır). Bkz. DEPLOY_VPS.md §8-9.
REGISTRATION_MODE=open

# ── Feature bayrakları (açma-önkoşulu yerine gelene dek KAPALI) ───────────────
# Yükleme: gerçek CSAM tarayıcı (R5) yokken false → S3/R2 değişkenleri de gerekmez.
UPLOADS_ENABLED=false
ATTACHMENT_SCAN_ENABLED=false
# Video/ekran (C4): lansman-hazırlık önkoşulları (purge + davet sistemi) sonrası true.
CAMERA_ENABLED=false
SCREEN_ENABLED=false

# ── S3 / R2 (yalnız UPLOADS_ENABLED=true olunca ZORUNLU) ─────────────────────
# UPLOADS_ENABLED=false iken bu blok boş kalabilir (config fail-fast atlanır).
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=kankaverse
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://<public-r2-domain>
