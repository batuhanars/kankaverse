{
  "name": "kankaverse-desktop",
  "version": "1.0.0",
  "description": "Kankaverse masaüstü istemcisi",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.kankaverse.desktop",
    "productName": "Kankaverse",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*"
    ],
    "extraResources": [
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "kankaverse-setup.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Network",
      "artifactName": "kankaverse.${ext}"
    }
  }
}
