generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  EMAIL_CHANGE
  EMAIL_CHANGE_UNDO
}

enum VerificationStatus {
  NONE
  EDEVLET_VERIFIED
}

enum DmPolicy {
  EVERYONE
  FRIENDS
  NONE
}

enum MediaPolicy {
  EVERYONE
  FRIENDS
  NONE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum GuildRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  GUILD_TEXT
  GUILD_VOICE
  DM
  GROUP_DM
}

enum ScanStatus {
  PENDING
  CLEAN
  FLAGGED
}

enum EventLocationType {
  VOICE_CHANNEL
  EXTERNAL
}

enum EventRecurrence {
  NONE      // MVP — yalnız bu kullanılır
  DAILY
  WEEKLY
  MONTHLY
}

enum EventStatus {
  SCHEDULED // MVP varsayılan
  ACTIVE
  COMPLETED
  CANCELED
}

enum NotificationType {
  MENTION
  FRIEND_REQUEST
  FRIEND_ACCEPT
}

model User {
  id                  String             @id @default(cuid())
  username            String             @unique
  email               String             @unique
  passwordHash        String
  birthDate           DateTime
  isMinor             Boolean
  isModerator         Boolean            @default(false)
  verificationStatus  VerificationStatus @default(NONE)
  dmPolicy            DmPolicy           @default(FRIENDS)
  mediaPolicy         MediaPolicy        @default(FRIENDS)
  profileDiscoverable Boolean            @default(true)
  emailVerifiedAt     DateTime?
  avatarUrl           String?
  bio                 String?
  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  twoFactorEnabled    Boolean            @default(false)
  totpSecret          String?
  deletionRequestedAt DateTime?
  friendCode          String          @unique
  sessions            Session[]
  memberships         GuildMember[]
  ownedGuilds         Guild[]            @relation("GuildOwner")
  messages            Message[]
  authTokens          AuthToken[]
  recoveryCodes       RecoveryCode[]
  friendshipsSent     Friendship[]       @relation("FriendRequester")
  friendshipsReceived Friendship[]       @relation("FriendAddressee")
  blocksMade          UserBlock[]        @relation("Blocker")
  blocksReceived      UserBlock[]        @relation("Blocked")
  channelMemberships  ChannelMember[]
  ownedChannels       Channel[]          @relation("ChannelOwner")
  createdInvites      Invite[]           @relation("InviteCreator")
  attachments         Attachment[]
  reportsFiled        Report[]           @relation("Reporter")
  reportResolutions   Report[]           @relation("ReportResolver")
  moderationActions   ModerationAction[] @relation("ModeratorActions")
  moderationTargets   ModerationAction[] @relation("ModerationTargets")
  auditLogs           AuditLog[]         @relation("AuditActor")
  channelReads        ChannelRead[]
  voiceSessions       VoiceSession[]
  createdEvents       GuildEvent[]       @relation("EventCreator")
  eventInterests      GuildEventInterest[]
  notifications       Notification[]     @relation("UserNotifications")
  notificationsActed  Notification[]     @relation("NotificationActor")
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  type      AuthTokenType
  tokenHash String
  payload   String?       // EMAIL_CHANGE: hedef e-posta; EMAIL_CHANGE_UNDO: eski e-posta
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, type])
  @@index([tokenHash])
}

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  refreshTokenHash String
  tokenFamily      String
  device           String?
  ip               String?
  lastActiveAt     DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

model Guild {
  id        String      @id @default(cuid())
  name      String
  ownerId   String
  owner     User        @relation("GuildOwner", fields: [ownerId], references: [id])
  adultsOnly Boolean    @default(false)
  iconUrl   String?
  description String?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  members   GuildMember[]
  channels  Channel[]
  invites   Invite[]
  categories ChannelCategory[]
  bans      GuildBan[]
  roles     Role[]
  events    GuildEvent[]
}

model GuildMember {
  id        String            @id @default(cuid())
  guildId   String
  guild     Guild             @relation(fields: [guildId], references: [id])
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  role      GuildRole         @default(MEMBER)
  joinedAt  DateTime          @default(now())
  roleLinks GuildMemberRole[]

  @@unique([guildId, userId])
  @@index([userId])
}

model Role {
  id          String            @id @default(cuid())
  guildId     String
  guild       Guild             @relation(fields: [guildId], references: [id])
  name        String
  color       String            @default("#99AAB5")
  position    Int               @default(0)
  hoist       Boolean           @default(false)
  mentionable Boolean           @default(false)
  permissions String[]          @default([])
  iconUrl     String?
  isEveryone  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberLinks GuildMemberRole[]

  @@index([guildId])
}

model GuildMemberRole {
  id         String      @id @default(cuid())
  memberId   String
  member     GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime    @default(now())

  @@unique([memberId, roleId])
  @@index([roleId])
}

// Ortam-ban: kalıcı yasak (kick + tekrar davetle giremez). Davet-join'de kontrol edilir.
// userId/bannedById Prisma ilişkisi değil (User şemasını şişirmemek için); username ayrı sorgulanır.
model GuildBan {
  id         String   @id @default(cuid())
  guildId    String
  guild      Guild    @relation(fields: [guildId], references: [id])
  userId     String
  bannedById String
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
}

model ChannelCategory {
  id        String    @id @default(cuid())
  guildId   String
  guild     Guild     @relation(fields: [guildId], references: [id])
  name      String
  position  Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  channels  Channel[]

  @@index([guildId])
}

model Channel {
  id              String           @id @default(cuid())
  type            ChannelType      @default(GUILD_TEXT)
  guildId         String?
  guild           Guild?           @relation(fields: [guildId], references: [id])
  categoryId      String?
  category        ChannelCategory? @relation(fields: [categoryId], references: [id])
  name            String?
  ownerId         String?          // GROUP_DM: oluşturan kullanıcı; 1-1 DM + guild kanallarında null
  owner           User?            @relation("ChannelOwner", fields: [ownerId], references: [id])
  ageGated        Boolean          @default(false)
  isPrivate       Boolean          @default(false)
  position        Int              @default(0)
  slowModeSeconds Int              @default(0)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  messages        Message[]
  members         ChannelMember[]
  channelReads    ChannelRead[]
  voiceSessions   VoiceSession[]
  events          GuildEvent[]

  @@index([guildId])
}

// Ses kanalı T&S audit — append-only (presence DEĞİL, geçmiş).
// §4 davranış örüntüsü tespiti: yetişkin→çok sayıda minör teması sinyali.
// Anlık "şu an kim var" LiveKit room state + WS ile; bu tablo kalıcı geçmiş.
// Sözleşme: contracts/SPRINT_V2_LIVEKIT_CONTRACT.md §B2.
model VoiceSession {
  id        String    @id @default(cuid())
  channelId String
  channel   Channel   @relation(fields: [channelId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  joinedAt  DateTime  @default(now())
  leftAt    DateTime? // webhook participant_left ile set; null = (kayda göre) hâlâ içeride
  createdAt DateTime  @default(now())

  @@index([userId, joinedAt])
  @@index([channelId, leftAt])
}

model Message {
  id          String            @id @default(cuid())
  channelId   String
  channel     Channel           @relation(fields: [channelId], references: [id])
  authorId    String
  author      User              @relation(fields: [authorId], references: [id])
  content     String
  mentions    String[]          @default([])   // §2: bahsedilen + doğrulanmış userId listesi (tekilleştirilmiş, ≤10)
  replyToId   String?
  replyTo     Message?          @relation("MessageReply", fields: [replyToId], references: [id])
  replies     Message[]         @relation("MessageReply")
  editedAt    DateTime?
  deletedAt   DateTime?
  pinnedAt    DateTime?         // null = sabit değil; dolu = sabitlenme zamanı
  pinnedById  String?           // sabitleyen userId (scalar — FK/relation YOK, audit/görünüm için)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  attachments Attachment[]
  reactions   MessageReaction[]

  @@index([channelId, createdAt])
  @@index([channelId, pinnedAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id])
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Attachment {
  id          String     @id @default(cuid())
  uploaderId  String
  uploader    User       @relation(fields: [uploaderId], references: [id])
  messageId   String?    // mesaja iliştirilince set (önce PENDING, presign anında null olabilir)
  message     Message?   @relation(fields: [messageId], references: [id])
  storageKey  String     @unique  // S3 objesi anahtarı
  filename    String
  contentType String
  size        Int
  scanStatus  ScanStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  @@index([messageId])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id])
  addresseeId String
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id])
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model ChannelMember {
  id         String    @id @default(cuid())
  channelId  String
  channel    Channel   @relation(fields: [channelId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  lastReadAt DateTime?
  clearedAt  DateTime? // G4: kullanıcı DM'i inbox'tan temizledi; mesaj KAYDEDILIR, bu tarihten öncesi gizlenir
  createdAt  DateTime  @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique          // kısa, paylaşılabilir, URL-safe (8-char)
  guildId   String
  guild     Guild     @relation(fields: [guildId], references: [id])
  creatorId String
  creator   User      @relation("InviteCreator", fields: [creatorId], references: [id])
  maxUses   Int?                        // null = sınırsız
  uses      Int       @default(0)
  expiresAt DateTime?                   // null = süresiz
  deletedAt DateTime?                   // iptal (revoke)
  createdAt DateTime  @default(now())

  @@index([guildId])
}

// ─── Sprint 4B: Moderasyon Çekirdeği ──────────────────────────────────────────

enum ReportReason {
  SPAM
  HARASSMENT
  MINOR_SAFETY
  VIOLENCE
  CSAM
  SELF_HARM
  OTHER
}

enum ReportTarget {
  MESSAGE
  USER
  CHANNEL
  GUILD
}

enum ReportStatus {
  OPEN
  TRIAGED
  RESOLVED
  DISMISSED
  ESCALATED
}

enum ModActionType {
  WARN
  MUTE
  KICK
  BAN
  CONTENT_REMOVE
  SHADOW_LIMIT
}

model Report {
  id              String       @id @default(cuid())
  reporterId      String
  reporter        User         @relation("Reporter", fields: [reporterId], references: [id])
  targetType      ReportTarget
  targetId        String
  reason          ReportReason
  description     String?
  status          ReportStatus @default(OPEN)
  priority        Int          @default(0)
  // 🔴 KURUL §0: contextSnapshot = yalnız minimal referans — kullanıcı içeriği/kanıt YAKALANMAZ
  // Gerçek kanıt-yakalama hukuk görüşü sonrası (KVKK dayanak + retention)
  contextSnapshot Json
  resolvedById    String?
  resolvedBy      User?        @relation("ReportResolver", fields: [resolvedById], references: [id])
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())

  @@index([status, priority])
  @@index([targetType, targetId])
}

model ModerationAction {
  id              String        @id @default(cuid())
  moderatorId     String
  moderator       User          @relation("ModeratorActions", fields: [moderatorId], references: [id])
  targetUserId    String
  targetUser      User          @relation("ModerationTargets", fields: [targetUserId], references: [id])
  type            ModActionType
  scope           String?       // guildId | null = global
  reason          String
  relatedReportId String?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())

  @@index([targetUserId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // "moderation.ban", "moderation.mute", "report.resolve", ...
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// ─── Sprint 6.2: Guild Kanal Okunmamış Takibi ────────────────────────────────

model ChannelRead {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])
  lastReadAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([userId])
}

// ─── Sprint V3: Ortam Etkinlikleri (Scheduled Events) ────────────────────────
// recurrence/status/coverImageId şema-foresight (sahip onaylı yarın); MVP'de motor YOK.

model GuildEvent {
  id               String            @id @default(cuid())
  guildId          String
  guild            Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  creatorId        String
  creator          User              @relation("EventCreator", fields: [creatorId], references: [id])

  name             String            // "Etkinlik Konusu" (zorunlu)
  description      String?           // markdown (mevcut markdown render boru hattı)

  locationType     EventLocationType
  channelId        String?           // VOICE_CHANNEL ise zorunlu
  channel          Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  externalLocation String?           // EXTERNAL ise zorunlu (metin/konum/link, düz metin)

  startAt          DateTime
  endAt            DateTime?         // opsiyonel

  recurrence       EventRecurrence   @default(NONE)   // motor yarın
  status           EventStatus       @default(SCHEDULED) // otomatik geçiş yarın
  coverImageId     String?           // Attachment (yarın); MVP null

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  interests        GuildEventInterest[]

  @@index([guildId, startAt])
}

model GuildEventInterest {
  id        String     @id @default(cuid())
  eventId   String
  event     GuildEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           // ALICI
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType

  actorId   String?          // tetikleyen (mesaj yazarı / istek gönderen) — User
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  guildId   String?          // mention bağlamı (navigasyon)
  channelId String?          // mention: zıplama hedefi kanal
  messageId String?          // mention: zıplama hedefi mesaj
  preview   String?          // mention metni anlık görüntüsü (≤120; mesaj sonradan silinse de kalır)

  readAt    DateTime?        // null = okunmamış
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
