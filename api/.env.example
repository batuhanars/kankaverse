DATABASE_URL="postgresql://kankaverse:kankaverse_dev@localhost:5432/kankaverse?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="CHANGE_ME_minimum_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_minimum_32_chars"
PORT=3001

# E-posta — dev'de yorum satırı bırakılabilir (konsol adaptörü devreye girer)
# Production'da RESEND_API_KEY zorunludur (fail-fast)
# RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@kankaverse.app
FRONTEND_URL=http://localhost:5173

# Refresh cookie SameSite — deploy topolojisi (varsayılan 'lax').
#  - Aynı-site (app./api. aynı kök domain): tanımsız bırak (lax yeterli).
#  - Çapraz-site (düz *.vercel.app + *.railway.app): COOKIE_SAMESITE=none (tarayıcı Secure+https ister; prod zaten https).
# COOKIE_SAMESITE=none

# 2FA — openssl rand -base64 32 ile üret (tam 32 byte = 44 karakter base64)
# Production'da zorunludur; dev'de opsiyonel (2FA çalışmaz ama boot devam eder)
TOTP_ENC_KEY=CHANGE_ME_32_bytes_base64_encoded_key_here

# Uygulama adı (TOTP issuer label, varsayılan: Kankaverse)
# APP_NAME=Kankaverse

# ── LiveKit ses kanalları (audio-only) ──────────────────────────────────────
# Dev'de yoksa ses özelliği devre dışı (endpoint 503 VOICE_DISABLED), boot devam eder.
# Prod'da üçü de ZORUNLU (fail-fast). LiveKit Cloud → Settings → Keys.
# LIVEKIT_API_KEY=APIxxxx
# LIVEKIT_API_SECRET=xxxx
# LIVEKIT_URL=wss://<proje>.livekit.cloud

# Hesap silme kalıcı purge — varsayılan false (R6 KVKK hukuk onayı bekleniyor)
# PURGE_ENABLED=false

# Yeni hesap DM kilidi — yabancıdan DM kapalı süre (gün, varsayılan 7) [§5.1.b]
# NEW_ACCOUNT_DM_LOCK_DAYS=7

# Yeni üye karantinası — ortak-ortam basamağı kilidi (saat, varsayılan 24) [Sprint 7B]
# 0 = karantina kapalı (kaçış valfi)
# QUARANTINE_HOURS=24

# ── S3-uyumlu storage (MinIO dev / prod S3-uyumlu sağlayıcı) ──────────────────
# Dev: docker-compose MinIO varsayılanları (değiştirmeden çalışır)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kankaverse
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/kankaverse

# Dosya boyutu limiti (MB, varsayılan 25)
# MAX_UPLOAD_MB=25

# LANSMAN: ATTACHMENT_SCAN_ENABLED=true + gerçek CSAM tarayıcı olmadan canlıya ALINMAZ (R5)
# Dev'de false bırak (auto-CLEAN — feature test edilebilir)
# Prod'da gerçek tarayıcı bağlandığında true yap (R5 tamamlandıktan sonra)
# ATTACHMENT_SCAN_ENABLED=false

# Dosya yükleme feature-flag — D14 riski: CSAM tarayıcı olmadan kapalı önizlemede false yap
# Dev varsayılan: true (yorum satırı bırakılabilir). Kapalı önizleme: UPLOADS_ENABLED=false
# UPLOADS_ENABLED=true

# ── Video/Ekran paylaşımı (BUILD-DARK — Sprint C4) ───────────────────────────
# Default false → bayraklar false iken mintToken yalnız MICROPHONE grant eder (audio-only korunur).
# Açma önkoşulları: davet-kodlu kayıt + açık-kayıt kapalı + R7 incelemesi tamam (bkz. §0.1).
# CAMERA_ENABLED=false      # kamera (görüntülü) yayını grant'i — default false
# SCREEN_ENABLED=false      # ekran paylaşımı grant'i — default false

# ── Kayıt Modu — Kapalı-Kayıt Fazı (Sprint Closed-Registration) ─────────────
# 'open'   (varsayılan): kayıt açık, davet kodu yok sayılır — mevcut davranış, regresyon güvenli.
# 'invite': yalnız geçerli 8-karakter davet koduyla kayıt (yayın öncesi hedef mod).
# 'closed': kayıt tamamen kapalı — purge sonrası dondurma / acil kapatma için.
# Geçersiz değer → fail-closed: bilinmeyen mod 'closed' olarak davranır (T&S prensibi).
REGISTRATION_MODE=open
