DATABASE_URL="postgresql://kankaverse:kankaverse_dev@localhost:5432/kankaverse?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="CHANGE_ME_minimum_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_minimum_32_chars"
PORT=3001

# E-posta — dev'de yorum satırı bırakılabilir (konsol adaptörü devreye girer)
# Production'da RESEND_API_KEY zorunludur (fail-fast)
# RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@kankaverse.app
FRONTEND_URL=http://localhost:5173

# 2FA — openssl rand -base64 32 ile üret (tam 32 byte = 44 karakter base64)
# Production'da zorunludur; dev'de opsiyonel (2FA çalışmaz ama boot devam eder)
TOTP_ENC_KEY=CHANGE_ME_32_bytes_base64_encoded_key_here

# Uygulama adı (TOTP issuer label, varsayılan: Kankaverse)
# APP_NAME=Kankaverse

# Hesap silme kalıcı purge — varsayılan false (R6 KVKK hukuk onayı bekleniyor)
# PURGE_ENABLED=false
