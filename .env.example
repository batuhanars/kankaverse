# Yerel geliştirme altyapısı (docker-compose) için değişkenler.
# Kopyala:  cp .env.example .env   (.env git'e gitmez)

POSTGRES_USER=kankaverse
POSTGRES_PASSWORD=kankaverse_dev
POSTGRES_DB=kankaverse
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# api/ servisi bu bağlantı dizelerini kullanır (api/.env içine yazılır):
#   DATABASE_URL="postgresql://kankaverse:kankaverse_dev@localhost:5432/kankaverse?schema=public"
#   REDIS_URL="redis://localhost:6379"
# JWT sırları (api/.env — argon2 + access/refresh imzaları), kurulumda üretilir:
#   JWT_ACCESS_SECRET="<rastgele-uzun-değer>"
#   JWT_REFRESH_SECRET="<rastgele-uzun-değer>"

# MinIO (S3-uyumlu yerel storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=kankaverse
